{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sb/:path*", "destination": "/api/supaproxy?_p=:path*" },
    { "source": "/pos/:path*", "destination": "/pos.html" },
    { "source": "/pos", "destination": "/pos.html" },
    { "source": "/:path((?!api/|sb/).*)", "destination": "/index.html" }
  ]
}
